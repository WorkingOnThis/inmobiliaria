# ============================================================================
# Arce Administración — env vars
#
# Copy this file to .env (dev) or set the vars in your host's dashboard (prod).
# Never commit .env or any file with real secrets.
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED IN ALL ENVIRONMENTS
# ----------------------------------------------------------------------------

# PostgreSQL connection string. In dev, point at a Neon branch.
# In prod, use the production Neon branch (or another Postgres host).
# Format: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=

# Better Auth session-signing secret. CRITICAL — never reuse between envs.
# Generate fresh: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of the app. Used by Better Auth for callback URLs and CORS.
# In dev: http://localhost:3000
# In prod: https://your-domain.com (no trailing slash)
BETTER_AUTH_URL=

# ----------------------------------------------------------------------------
# REQUIRED IN PRODUCTION
# (in dev these are optional — sendEmail logs a warning and skips)
# ----------------------------------------------------------------------------

# Gmail account for sending verification + receipt emails.
# In prod, sendEmail throws if either is missing (fail-fast).
GMAIL_USER=
# App password (NOT your Google account password). Generate at:
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# Auth secret for the cleanup cron endpoint.
# In prod (Vercel Cron), set the same value here AND in Vercel project settings.
# In dev, optional — without it the endpoint returns 503 (fail-closed).
# Generate fresh: openssl rand -base64 32
CRON_SECRET=

# ----------------------------------------------------------------------------
# REQUIRED ON VERCEL (prod) — auto-set after creating a Blob store
# ----------------------------------------------------------------------------

# Vercel Blob token for uploads (tasks/contracts/movimientos).
# Vercel sets this automatically after you connect a Blob store to the project.
# Without it, the storage adapter falls back to the local filesystem
# (which doesn't work on Vercel — uploads will fail).
BLOB_READ_WRITE_TOKEN=

# ----------------------------------------------------------------------------
# OPTIONAL
# ----------------------------------------------------------------------------

# Public app URL fallback (used by client-side Better Auth).
# Usually same as BETTER_AUTH_URL. If both are set, BETTER_AUTH_URL wins.
NEXT_PUBLIC_APP_URL=

# API URL for the Eden Treaty client (currently unused — ElysiaJS catch-all
# only has health check). Defaults to http://localhost:3000.
NEXT_PUBLIC_API_URL=

# Google OAuth (provider currently configured but not actively used).
# Without these, Better Auth logs a warning at startup but doesn't fail.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
