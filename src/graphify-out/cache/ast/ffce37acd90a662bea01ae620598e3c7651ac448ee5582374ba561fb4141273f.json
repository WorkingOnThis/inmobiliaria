nts\\tenants\\rent-projection-panel.tsx", "source_location": "L26"}, {"caller_nid": "tenants_rent_projection_panel_rentprojectionpanel", "callee": "(() => {\n                const tramosPerYear = 12 / data.adjustmentFrequency;\n                const firstCurrentIdx = data.tramos.findIndex((t) => !t.isPast);\n                type Group = { year: number; items: { tramo: typeof data.tramos[0]; idx: number }[] };\n                const groups: Group[] = [];\n                // Filter out stale cached tramos that lack tramoNumber (HMR dev artifact)\n                const validTramos = data.tramos.filter((t) => typeof t.tramoNumber === \"number\");\n                validTramos.forEach((t, i) => {\n                  const year = Math.ceil(t.tramoNumber / tramosPerYear);\n                  let g = groups.find((g) => g.year === year);\n                  if (!g) { g = { year, items: [] }; groups.push(g); }\n                  g.items.push({ tramo: t, idx: data.tramos.indexOf(t) });\n                });\n                return (\n                  <div className=\"flex flex-wrap gap-y-2 px-4 pt-3 items-center gap-x-3\">\n                    {groups.map((group, gi) => (\n                      <div key={group.year} className=\"flex items-center gap-1\">\n                        <span className=\"text-[10px] text-muted-foreground/50 font-medium mr-0.5 whitespace-nowrap\">\n                          A\u00f1o {group.year}\n                        </span>\n                        {group.items.map(({ tramo: t, idx: i }) => {\n                          const isCurrent = i === firstCurrentIdx;\n                          const label = isCurrent\n                            ? `Tramo actual (${t.tramoNumber})`\n                            : `Tramo ${t.tramoNumber}`;\n                          return (\n                            <button\n                              key={t.tramoStart}\n                              onClick={() => setTramoIdx(i)}\n                              className={`px-3 py-1 rounded text-xs font-medium transition-colors ${\n                                i === tramoIdx\n                                  ? \"bg-primary text-primary-foreground\"\n                                  : \"bg-surface-mid text-muted-foreground hover:text-foreground\"\n                              }`}\n                            >\n                              {label}\n                              {t.hasProjected && (\n                                <span className=\"ml-1 text-amber-400 font-bold\">!</span>\n                              )}\n                            </button>\n                          );\n                        })}\n                        {gi < groups.length - 1 && (\n                          <span className=\"text-muted-foreground/30 text-xs ml-2\">\u00b7</span>\n                        )}\n                      </div>\n                    ))}\n                  </div>\n                );\n              })", "is_member_call": false, "source_file": "F:\\Documentos\\Proyectos\\inmobiliaria\\src\\components\\tenants\\rent-projection-panel.tsx", "source_location": "L65"}, {"caller_nid": "tenants_rent_projection_panel_rentprojectionpanel", "callee": "toFixed", "is_member_call": true, "source_file": "F:\\Documentos\\Proyectos\\inmobiliaria\\src\\components\\tenants\\rent-projection-panel.tsx", "source_location": "L129"}, {"caller_nid": "tenants_rent_projection_panel_rentprojectionpanel", "callee": "map", "is_member_call": true, "source_file": "F:\\Documentos\\Proyectos\\inmobiliaria\\src\\components\\tenants\\rent-projection-panel.tsx", "source_location": "L148"}, {"caller_nid": "tenants_rent_projection_panel_rentprojectionpanel", "callee": "join", "is_member_call": true, "source_file": "F:\\Documentos\\Proyectos\\inmobiliaria\\src\\components\\tenants\\rent-projection-panel.tsx", "source_location": "L176"}, {"caller_nid": "tenants_rent_projection_panel_rentprojectionpanel", "callee": "reverse", "is_member_call": true, "source_